#
# DFST CONFIGURATION FILE
# 

# ----------------
# VERSION SETTINGS
# ----------------
DFST_VERSION=1
DFST_DATA_DIR=~/.dfst/${DFST_VERSION}
DFST_INSTALL_BASE_DIR=/opt/dfst/
DFST_INSTALL_DIR=${DFST_INSTALL_BASE_DIR}${DFST_VERSION}
DFST_VERSIONED_NAME=dfst${DFST_VERSION}
DFST_SUBNAME=main

# -----------------
# SERVICES SETTINGS
# -----------------
SVC_DNS_ALPINE_IMAGE=alpine
SVC_DNS_ALPINE_TAG=3.22
SVC_DNS_ALPINE_VERSION=${SVC_DNS_ALPINE_IMAGE}:${SVC_DNS_ALPINE_TAG}

SVC_DNS_CADDY_IMAGE=caddy
SVC_DNS_CADDY_TAG=2.10.2-alpine
SVC_DNS_CADDY_VERSION=${SVC_DNS_CADDY_IMAGE}:${SVC_DNS_CADDY_TAG}

# ----------------
# NETWORK SETTINGS
# ----------------
DFST_DNS_NET_SUBNET=172.20.0.0/16 
DFST_DNS_NET_GATEWAY=172.20.0.1       
DFST_DNS_IP=172.20.0.2                                # 1 IP per version
DFST_DNS_IP_RANGE=172.20.16.0/20                      # Allocated to services

# Static/Non-DHCP range: 172.20.0.0/20 (4,096 IPs: 172.20.0.0 - 172.20.15.255)
# DHCP range: 172.20.16.0/20 to 172.20.255.255 (remaining ~61,440 IPs)

# --
# CA
# --
CA_FILE_PATH=${DFST_DATA_DIR}/certs/ca.crt