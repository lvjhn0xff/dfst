#
# DFST CONFIGURATION FILE
# 

# ----------------
# VERSION SETTINGS
# ----------------
DFST_VERSION=1
DFST_DATA_DIR=~/.dfst/${DFST_VERSION}
DFST_INSTALL_DIR=/opt/dfst/${DFST_VERSION}
DFST_VERSIONED_NAME=dfst${DFST_VERSION}
DFST_SUBNAME=main

# -----------------
# SERVICES SETTINGS
# -----------------
SVC_DNS_ALPINE_IMAGE=alpine
SVC_DNS_ALPINE_TAG=3.22
SVC_DNS_ALPINE_VERSION=${SVC_DNS_ALPINE_IMAGE}:${SVC_DNS_ALPINE_TAG}

SVC_DNS_CADDY_IMAGE=caddy
SVC_DNS_CADDY_TAG=2.10.2-alpine
SVC_DNS_CADDY_VERSION=${SVC_DNS_CADDY_IMAGE}:${SVC_DNS_CADDY_TAG}

# ----------------
# NETWORK SETTINGS
# ----------------
DFST_DNS_NET_SUBNET=192.168.10.0/24 
DFST_DNS_NET_GATEWAY=192.168.10.1       
DFST_DNS_IP=192.168.10.2                                # 1 IP per version

